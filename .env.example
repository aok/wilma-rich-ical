# LLM for message processing
LLM_PROVIDER=anthropic          # or openai
LLM_MODEL=claude-haiku-4-5-20251001
ANTHROPIC_API_KEY=sk-ant-...

REFRESH_INTERVAL=30             # minutes
PORT=3456
TZ=Europe/Helsinki

# Per-child tokens (auto-generated by `wilma-icald setup`)
# TOKEN_FIRSTNAME=<64-char-hex>

# School config per child (optional, for subject name mappings and schedule filters)
# Available: syk
# SCHOOL_FIRSTNAME=syk

# For stable public URLs, set your Cloudflare tunnel hostname:
# TUNNEL_HOSTNAME=wilma.example.com
