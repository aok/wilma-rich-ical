{
  "name": "wilma-icald",
  "version": "0.2.0",
  "type": "module",
  "description": "Self-hosted enriched iCal feeds from Wilma school data",
  "license": "MIT",
  "author": "Oskari Kettunen",
  "keywords": [
    "wilma",
    "ical",
    "calendar",
    "school",
    "icalendar"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aok/wilma-rich-ical.git"
  },
  "homepage": "https://github.com/aok/wilma-rich-ical#readme",
  "bugs": {
    "url": "https://github.com/aok/wilma-rich-ical/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "wilma-icald": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "setup": "tsx src/setup.ts",
    "test": "vitest run",
    "prepublishOnly": "tsc"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.79",
    "@ai-sdk/openai": "^3.0.65",
    "@wilm-ai/wilma-cli": "^1.5.0",
    "@wilm-ai/wilma-client": "^1.4.0",
    "ai": "^6.0.191",
    "date-fns": "^4.3.0",
    "date-fns-tz": "^3.2.0",
    "dotenv": "^17.4.2"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
